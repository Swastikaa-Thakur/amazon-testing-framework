<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    testng.xml
    This file tells TestNG which tests to run and in what order.
    You can comment out <class> lines to skip specific test files.
-->

<suite name="Amazon.in Test Suite" verbose="1">

    <test name="Home Page Tests">
        <classes>
            <class name="tests.HomePageTest"/>
        </classes>
    </test>

    <test name="Search Tests">
        <classes>
            <class name="tests.SearchTest"/>
        </classes>
    </test>

</suite>
